{
  "$schema": "https://raw.githubusercontent.com/nicklasxyz/tauri-v2-schema/main/tauri.conf.json",
  "productName": "Yames",
"version": "0.7.2",
  "identifier": "com.yames.metronome",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Yames",
        "url": "index.html?window=main",
        "width": 800,
        "height": 900,
        "minWidth": 480,
        "minHeight": 820,
        "resizable": true,
        "decorations": true,
        "alwaysOnTop": true,
        "center": true,
        "visible": false,
        "theme": "Dark",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
      {
        "label": "floating",
        "title": "Yames Widget",
        "url": "index.html?window=floating",
        "width": 400,
        "height": 160,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visibleOnAllWorkspaces": true,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Yames"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Alberto Delgado Cabrera (BBG489SR42)",
      "entitlements": null
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCODVBQzU2Q0NFRTI1MjMKUldRakplN01WcXlGSzBwd0NNazNtbXplOGtpdEREeDU4NTN1Vk9ZVFR4UUhZMmR2VzZpcWU1Z3UK",
      "endpoints": [
        "https://github.com/turutupa/yames/releases/latest/download/latest.json"
      ]
    }
  }
}
